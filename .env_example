APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info
APP_RELOAD=0

# Write API keys
MT5_API_KEY=
# MT5_API_KEYS=key1,key2,key3

# Read API keys
# If left empty, read access falls back to write keys
MT5_READ_API_KEY=
# MT5_READ_API_KEYS=readkey1,readkey2

# Heartbeat validation and logging
MT5_MAX_TS_DRIFT_SEC=300
MT5_LOG_HEARTBEAT=1

# History retention
MT5_HISTORY_RETENTION_SEC=3888000
MT5_HISTORY_MAX_POINTS_PER_TERMINAL=10000

# System monitor
SYSTEM_MONITOR_MIN_REFRESH_SEC=1.0

# CORS
# Use * to allow all origins, or comma-separated origins
CORS_ALLOW_ORIGINS=*
# CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:5173

# Optional ngrok support
ENABLE_NGROK=0
NGROK_AUTHTOKEN=
NGROK_DOMAIN=
